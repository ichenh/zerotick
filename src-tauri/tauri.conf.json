{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroTick",
  "version": "0.1.4",
  "identifier": "com.zerotick.desktop",
  "build": {
    "beforeDevCommand": "node scripts/prepare-dev.mjs && npm run dev",
    "devUrl": "http://127.0.0.1:55555",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ZeroTick",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Windows 硬件断连与系统故障实时诊断",
    "longDescription": "ZeroTick 是一款轻量级 Windows 系统故障诊断工具，实时追踪 USB/蓝牙断连、蓝牙服务异常与 BSOD 追溯，支持托盘静默驻留、原生通知与一键修复。",
    "copyright": "Copyright © 2026 ZeroTick Contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
