{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroTick",
  "version": "0.2.0",
  "identifier": "com.zerotick.desktop",
  "build": {
    "beforeDevCommand": "node scripts/prepare-dev.mjs && npm run dev",
    "devUrl": "http://127.0.0.1:55555",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZeroTick",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "面向普通用户的 Windows 设备与系统故障诊断工具",
    "longDescription": "ZeroTick 集中诊断网络、音频、USB 存储、蓝牙、设备驱动、蓝屏和端口问题，提供易懂说明、安全操作与一键修复，并为高级用户保留底层诊断证据。",
    "copyright": "Copyright © 2026 ZeroTick Contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
