  "version": "0.2.5",
  "description": "Approachable Windows diagnostics and repair for network, audio, removable storage, Bluetooth, drivers, BSODs, and ports",
  "homepage": "https://github.com/ichenh/zerotick#readme",
  "repository": {
    "type": "git",
